<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:clipChildren="false">

    <!-- Unified Bottom Sheet Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_sheet"
        android:orientation="vertical"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="16dp">

        <!-- Top Drag Handle -->
        <View
            android:layout_width="32dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_bottom_sheet_handle"
            android:layout_marginBottom="16dp" />

        <!-- Response Area (Directly inside sheet, hidden by default) -->
        <LinearLayout
            android:id="@+id/expanded_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_sparkle_ai"
                    android:contentDescription="Speaker"
                    android:tint="@color/colorAccent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Loki AI"
                    android:textColor="@color/overlay_text_primary"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <!-- Placeholder for audio icon like in the design -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_speaker"
                    android:contentDescription="Speaker Volume" />

            </LinearLayout>

            <!-- Markdown Response Body -->
            <TextView
                android:id="@+id/text_response_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/overlay_text_primary"
                android:textSize="16sp"
                android:lineSpacingExtra="6dp" />

            <!-- Footer (Feedback / Share) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="start"
                android:layout_marginTop="16dp">

                <ImageButton
                    android:id="@+id/btn_thumb_up"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_thumb_up"
                    android:contentDescription="Thumb Up"
                    android:layout_marginEnd="16dp"/>

                <ImageButton
                    android:id="@+id/btn_thumb_down"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_thumb_down"
                    android:contentDescription="Thumb Down"
                    android:layout_marginEnd="16dp"/>

                <ImageButton
                    android:id="@+id/btn_share"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_share"
                    android:contentDescription="Share"
                    android:layout_marginEnd="16dp"/>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_scan_context"
                    android:contentDescription="Options"
                    android:layout_gravity="center_vertical"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Internal Input Container (No longer floating pill) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input"
            android:padding="4dp">

            <!-- Container for all input elements -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="visible">

                <ImageButton
                    android:id="@+id/btn_add"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_add"
                    android:contentDescription="Add" />

                <ImageButton
                    android:id="@+id/btn_scan"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_scan_context"
                    android:contentDescription="Scan Context" />

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp">

                    <!-- Text Input -->
                    <EditText
                        android:id="@+id/input_text"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="Ask Loki"
                        android:textColorHint="@color/overlay_text_secondary"
                        android:textColor="@color/overlay_text_primary"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:inputType="textShortMessage"
                        android:imeOptions="actionSend"
                        android:singleLine="true"
                        android:textSize="16sp" />

                    <!-- Listening / Processing Mode -->
                    <LinearLayout
                        android:id="@+id/layout_processing_mode"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:gravity="center"
                        android:visibility="gone">

                        <ProgressBar
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:indeterminate="true"
                            android:indeterminateTint="@color/colorAccent" />
                    </LinearLayout>
                </FrameLayout>

                <!-- Mic with Accent Background -->
                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="4dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_mic_accent" />

                    <ImageButton
                        android:id="@+id/btn_mic"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_mic"
                        android:tint="@color/overlay_mic_accent_icon"
                        android:contentDescription="Microphone" />
                </FrameLayout>

                <ImageButton
                    android:id="@+id/btn_sparkle"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_sparkle_ai"
                    android:contentDescription="AI Model" />
            </LinearLayout>
        </FrameLayout>

    </LinearLayout>
</FrameLayout>
