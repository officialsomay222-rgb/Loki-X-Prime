<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:clipToPadding="false"
    android:clipChildren="false">

    <!-- Container aligned to the bottom for the overlay content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:clipToPadding="false"
        android:clipChildren="false">

        <!-- Expanded Response Card (Hidden by default) -->
        <LinearLayout
            android:id="@+id/expanded_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="20dp"
            android:visibility="gone"
            android:elevation="8dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_speaker"
                    android:contentDescription="Speaker" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Loki AI"
                    android:textColor="@color/overlay_text_primary"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="· Context"
                    android:textColor="@color/overlay_text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Markdown Response Body -->
            <TextView
                android:id="@+id/text_response_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/overlay_text_primary"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp" />

            <!-- Footer (Feedback / Share) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_marginTop="16dp">

                <ImageButton
                    android:id="@+id/btn_thumb_up"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_thumb_up"
                    android:contentDescription="Thumb Up"
                    android:layout_marginEnd="8dp"/>

                <ImageButton
                    android:id="@+id/btn_thumb_down"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_thumb_down"
                    android:contentDescription="Thumb Down"
                    android:layout_marginEnd="8dp"/>

                <ImageButton
                    android:id="@+id/btn_share"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_share"
                    android:contentDescription="Share" />
            </LinearLayout>
        </LinearLayout>

        <!-- Main Input Pill -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_pill"
            android:padding="8dp"
            android:elevation="8dp">

            <!-- Container for all pill elements -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="visible">

                <ImageButton
                    android:id="@+id/btn_add"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_add"
                    android:contentDescription="Add" />

                <ImageButton
                    android:id="@+id/btn_scan"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_scan_context"
                    android:contentDescription="Scan Context" />

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp">

                    <!-- Text Input -->
                    <EditText
                        android:id="@+id/input_text"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_input"
                        android:hint="Ask Loki"
                        android:textColorHint="@color/overlay_text_secondary"
                        android:textColor="@color/overlay_text_primary"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:inputType="textShortMessage"
                        android:imeOptions="actionSend"
                        android:singleLine="true" />

                    <!-- Listening / Processing Mode -->
                    <LinearLayout
                        android:id="@+id/layout_processing_mode"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_input"
                        android:gravity="center"
                        android:visibility="gone">

                        <ProgressBar
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:indeterminate="true"
                            android:indeterminateTint="@color/colorAccent" />
                    </LinearLayout>
                </FrameLayout>

                <ImageButton
                    android:id="@+id/btn_mic"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_mic"
                    android:contentDescription="Microphone" />

                <ImageButton
                    android:id="@+id/btn_sparkle"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_sparkle_ai"
                    android:contentDescription="AI Model" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</FrameLayout>
